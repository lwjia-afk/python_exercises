# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# IDE
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Logs
*.log

# Claude Code (local settings are machine-specific)
.claude/settings.local.json

# Data science projects — large data files and artifacts
projects/*/data/*.csv
projects/*/data/*.zip
projects/*/data/*.parquet
projects/*/outputs/*.pkl
projects/*/outputs/*.joblib
projects/*/outputs/submission*.csv
# Keep the directories themselves tracked
!projects/*/data/.gitkeep
!projects/*/outputs/.gitkeep
